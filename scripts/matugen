#!/usr/bin/env bash

# When DMS tries to generate colors, it runs: matugen image /path/to/image.jpg
if [ "$1" = "image" ]; then
    IMAGE=$(realpath "$2")

    # Update Pandora's config file
    sed -i -E 's|image ".*"|image "'"$IMAGE"'"|' ~/.config/pandora/pandora.kdl

    # Restart Pandora silently
    pkill -INT pandora 2>/dev/null
    sleep 0.5
    pandora > /dev/null 2>&1 & disown
fi

# Finally, execute the REAL system matugen so DMS still gets its theme colors!
exec /run/current-system/sw/bin/matugen "$@"
