#!/usr/bin/env bash

# 1. Handle quick checks instantly
if [[ "$1" == "--version" ]] || [[ "$1" == "-V" ]] || [[ "$1" == "--help" ]]; then
    exec /run/current-system/sw/bin/matugen "$@"
fi

echo "=== $(date) ===" >> /tmp/matugen-wrapper.log
echo "matugen called with: $@" >> /tmp/matugen-wrapper.log

ARGS=("$@")
IMAGE=""

# 2. Check for image path
while [[ $# -gt 0 ]]; do
    if [[ "$1" == "image" ]]; then
        IMAGE=$(realpath "$2")
        echo "Found image argument: $IMAGE" >> /tmp/matugen-wrapper.log
        break
    fi
    shift
done

if [[ -z "$IMAGE" ]]; then
    SESSION_FILE="$HOME/.local/state/DankMaterialShell/session.json"
    if [[ -f "$SESSION_FILE" ]]; then
        IMAGE=$(grep -o '"wallpaperPath": *"[^"]*"' "$SESSION_FILE" | head -n 1 | awk -F'"' '{print $4}')
    fi
fi

# 3. Apply to Pandora & SWWW (Silently redirecting everything to logs!)
if [[ -n "$IMAGE" ]] && [[ -f "$IMAGE" ]]; then
    sed -i -E 's|image "[^"]+"|image "'"$IMAGE"'"|' "$HOME/.config/pandora/pandora.kdl"
    ACTIVE_OUTPUT=$(niri msg outputs 2>/dev/null | grep -oE '\b(eDP|DP|HDMI-[A-Z]|Virtual|WL|VGA|DVI-[A-Z]|LVDS)-[0-9]+\b' | head -n 1)
    if [[ -n "$ACTIVE_OUTPUT" ]]; then
        sed -i -E 's|output "[^"]+"|output "'"$ACTIVE_OUTPUT"'"|' "$HOME/.config/pandora/pandora.kdl"
    fi

    pandora stop-daemon >> /tmp/matugen-wrapper.log 2>&1
    sleep 0.05
    rm -f /tmp/pandora*.sock /run/user/$(id -u)/pandora*.sock 2>/dev/null
    pandora > /tmp/pandora-crash.log 2>&1 & disown

    magick "$IMAGE" -resize 20% -blur 0x10 -resize 500% /tmp/overview-blur.jpg >> /tmp/matugen-wrapper.log 2>&1
    swww img /tmp/overview-blur.jpg --transition-type none >> /tmp/matugen-wrapper.log 2>&1
fi

# 4. RUN REAL MATUGEN (This is the ONLY thing allowed to write to stdout!)
/run/current-system/sw/bin/matugen "${ARGS[@]}"
REAL_EXIT_CODE=$?
echo "Real matugen exited with code: $REAL_EXIT_CODE" >> /tmp/matugen-wrapper.log

# 5. SYNC SDDM
if [[ -n "$IMAGE" ]] && [[ -f "$IMAGE" ]]; then
    echo "Syncing SDDM..." >> /tmp/matugen-wrapper.log

    # REMOVE first so the user takes ownership of the new file
    rm -f /var/sddm-background/wallpaper.jpg
    cp "$IMAGE" /var/sddm-background/wallpaper.jpg
    chmod 666 /var/sddm-background/wallpaper.jpg

    TEMPLATE="/run/current-system/sw/share/sddm/themes/ii-sddm-theme/SddmColors.qml"
    if [ -f "$TEMPLATE" ]; then
        cat << EOF > /tmp/sddm-matugen.toml
[config]
wallpaper_dir = "/tmp"

[templates.sddm]
input_path = "$TEMPLATE"
output_path = "/var/sddm-background/Colors.qml"
EOF

        # Remove old colors file
        rm -f /var/sddm-background/Colors.qml

        # GUARANTEED FIX: Use a hex color to generate the palette silently instead of parsing the image interactively
        /run/current-system/sw/bin/matugen --config /tmp/sddm-matugen.toml color hex "#89b4fa" >> /tmp/matugen-wrapper.log 2>&1

        # If Matugen successfully created the file, set permissions
        if [ -f /var/sddm-background/Colors.qml ]; then
            chmod 666 /var/sddm-background/Colors.qml
        else
            echo "Matugen failed to generate Colors.qml" >> /tmp/matugen-wrapper.log
        fi
    fi
fi

exit $REAL_EXIT_CODE
